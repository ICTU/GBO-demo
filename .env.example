# docker compose reads this file automatically on `up`. Copy to `.env`
# and fill in the values — `.env` is git-ignored, `.env.example` is not.
#
# ── Base (always required) ────────────────────────────────────────────
# Optional. Defaults to the pinned git submodule at vendor/nl-wallet
# (v0.4.1 — required, the preprod wallet app rejects v0.5.0's
# scheme-prefixed client_id). Init once with:
#   git submodule update --init vendor/nl-wallet
# NLWALLET_PATH=/absolute/path/to/your/nl-wallet-repo

# ── EUDI profile (only when running with `--profile eudi`) ────────────
#
# The wallet on a phone needs to reach the issuance-server, and the
# issuance-server needs to reach the eudi-adapter. Both need public
# HTTPS URLs. Pick one of three options:
#
#   (a) Own domain / reverse proxy
#       Point two HTTPS hosts at the compose ports and set the URLs
#       below. Skip CLOUDFLARE_TUNNEL_TOKEN.
#
#   (b) Cloudflare named tunnel (bundled)
#       Set CLOUDFLARE_TUNNEL_TOKEN and start compose with an extra
#       file:  docker compose -f docker-compose.yml -f docker-compose.cloudflare-tunnel.yml --profile eudi up
#       The two URLs must match the hostnames you configured in the
#       Cloudflare dashboard.
#
#   (c) Ad-hoc tunnel (ngrok, cloudflared --url, tailscale funnel, …)
#       Run it yourself, then paste the two URLs below.

# Public HTTPS URL where the wallet reaches the issuance-server.
# Also used by the frontend to build QR codes.
EUDI_PUBLIC_URL=https://eudi-is.yourdomain.tld/

# Reader-origin base URL published in reader_auth.json. Usually the
# same host as EUDI_PUBLIC_URL, but can differ if the reader-request
# origin is served from a separate hostname/certificate. No trailing
# slash.
EUDI_READER_ORIGIN_URL=https://eudi-is.yourdomain.tld

# Public HTTPS URL where the issuance-server fetches attestations from
# the eudi-adapter.
EUDI_BRI_URL=https://eudi-bri.yourdomain.tld/

# ── EUDI crypto (required for `make eudi-config` / `make demo-eudi`) ──
#
# The .example config files under services/eudi-issuance-server/config/
# contain placeholders that `make eudi-config` fills via `envsubst`.
# Real values are NOT in the public repo — for a working wallet-QR flow
# you need the shared BZK-non-prod-wallet-trusted keys/certs. Ask the
# repo maintainer (jeroen.dekok@ictu.nl) out-of-band for the current
# values.
#
# All 6 fields are single-line base64. Leaving any of them empty makes
# eudi-issuance-server refuse to start.

# Reader-key + cert (disclosure_settings — used when reading BSN from
# the user's wallet PID). Shared across inkomensverklaring_2023/2024/2025.
EUDI_READER_KEY=
EUDI_READER_CERT=

# Issuer-key + cert for signing the inkomensverklaring attestation
# itself (attestation_settings).
EUDI_ISSUER_KEY=
EUDI_ISSUER_CERT=

# Status-list signing key + cert (attestation_settings.status_list).
EUDI_STATUS_KEY=
EUDI_STATUS_CERT=

# Only needed for option (b) above. Cloudflare Zero Trust → Networks →
# Tunnels → your tunnel → Install connector. The eyJ… string from
# `cloudflared service install eyJ…`.
# CLOUDFLARE_TUNNEL_TOKEN=eyJ...your-token-here...

# ── Passwords (required) ──────────────────────────────────────────────
# Postgres password for the EUDI postgres container (issuance-server +
# migrations). Compose fails loud if unset. Any string works for the
# local demo network.
# EUDI_POSTGRES_PASSWORD=
