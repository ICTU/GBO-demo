log_requests = true
structured_logging = false
issuer_trust_anchors = [
  # ca.gbo-issuer (local CA for inkomensverklaring)
  "",
  # issuance-ca.nonprod.wallet.edi.bzk.nl (pre-prod PID issuer CA, from wallet-config)
  ""
]
reader_trust_anchors = [""]
public_url = "https://issuer.example.com/"
universal_link_base_url = "walletdebuginteraction://wallet.edi.rijksoverheid.nl/"
wallet_client_ids = ["https://wallet.edi.rijksoverheid.nl"]
metadata = ["inkomensverklaring_metadata.json"]

[wallet_server]
ip = "0.0.0.0"
port = 18001

[internal_server]
ip = "127.0.0.1"
port = 8002

[storage]
# The compose stack overrides this via ISSUANCE_SERVER__STORAGE__URL.
# Placeholder value only — never used at runtime.
url = "postgres://localhost:5432/issuance_server"

[status_lists]
list_size = 100000
create_threshold_ratio = 0.1
expiry_in_hours = 24
refresh_threshold_ratio = 0.25
serve = true


[disclosure_settings.inkomensverklaring_2023]
private_key_type = "software"
private_key = "REPLACE_WITH_GENERATED_PRIVATE_KEY_BASE64"
certificate = "REPLACE_WITH_GENERATED_CERTIFICATE_BASE64"

[[disclosure_settings.inkomensverklaring_2023.dcql_query.credentials]]
id = "pid_credential"
format = "dc+sd-jwt"
meta = { vct_values = ["urn:eudi:pid:nl:1"] }
claims = [ { path = ["bsn"] } ]

[disclosure_settings.inkomensverklaring_2023.attestation_url_config]
base_url = "https://bri.example.com/"
trust_anchors = ["", "", ""]


[disclosure_settings.inkomensverklaring_2024]
private_key_type = "software"
private_key = "REPLACE_WITH_GENERATED_PRIVATE_KEY_BASE64"
certificate = "REPLACE_WITH_GENERATED_CERTIFICATE_BASE64"

[[disclosure_settings.inkomensverklaring_2024.dcql_query.credentials]]
id = "pid_credential"
format = "dc+sd-jwt"
meta = { vct_values = ["urn:eudi:pid:nl:1"] }
claims = [ { path = ["bsn"] } ]

[disclosure_settings.inkomensverklaring_2024.attestation_url_config]
base_url = "https://bri.example.com/"
trust_anchors = ["", "", ""]


[disclosure_settings.inkomensverklaring_2025]
private_key_type = "software"
private_key = "REPLACE_WITH_GENERATED_PRIVATE_KEY_BASE64"
certificate = "REPLACE_WITH_GENERATED_CERTIFICATE_BASE64"

[[disclosure_settings.inkomensverklaring_2025.dcql_query.credentials]]
id = "pid_credential"
format = "dc+sd-jwt"
meta = { vct_values = ["urn:eudi:pid:nl:1"] }
claims = [ { path = ["bsn"] } ]

[disclosure_settings.inkomensverklaring_2025.attestation_url_config]
base_url = "https://bri.example.com/"
trust_anchors = ["", "", ""]


[attestation_settings."nl.gbo.belastingdienst.inkomensverklaring"]
valid_days = 365
copies_per_format = { "dc+sd-jwt" = 4 }
private_key_type = "software"
private_key = "REPLACE_WITH_GENERATED_PRIVATE_KEY_BASE64"
certificate = "REPLACE_WITH_GENERATED_CERTIFICATE_BASE64"

[attestation_settings."nl.gbo.belastingdienst.inkomensverklaring".status_list]
context_path = "/tsl"
publish_dir = "/tsl-publish"
private_key_type = "software"
private_key = "REPLACE_WITH_GENERATED_PRIVATE_KEY_BASE64"
certificate = "REPLACE_WITH_GENERATED_CERTIFICATE_BASE64"
