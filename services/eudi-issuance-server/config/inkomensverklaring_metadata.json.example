{
  "vct": "nl.gbo.belastingdienst.inkomensverklaring",
  "name": "Inkomensverklaring",
  "description": "Aangifte inkomstenbelasting volgens de Belastingdienst (BD)",
  "display": [
    {
      "lang": "nl-NL",
      "name": "Inkomensverklaring",
      "description": "Verklaring van aangegeven inkomen (Belastingdienst)",
      "summary": "€{{verzamelinkomen}} ({{belastingjaar}})",
      "rendering": {
        "simple": {
          "background_color": "#0b5394",
          "text_color": "#ffffff"
        }
      }
    },
    {
      "lang": "en-US",
      "name": "Income statement",
      "description": "Statement of declared income (Dutch Tax Administration)",
      "summary": "€{{verzamelinkomen}} ({{belastingjaar}})",
      "rendering": {
        "simple": {
          "background_color": "#0b5394",
          "text_color": "#ffffff"
        }
      }
    }
  ],
  "claims": [
    {
      "path": ["belastingjaar"],
      "display": [
        { "lang": "nl-NL", "label": "Belastingjaar",     "description": "Jaar waarover het inkomen is vastgesteld" },
        { "lang": "en-US", "label": "Tax year",          "description": "Year for which the income was assessed" }
      ],
      "sd": "always",
      "svg_id": "belastingjaar"
    },
    {
      "path": ["indieningsdatum"],
      "display": [
        { "lang": "nl-NL", "label": "Indieningsdatum",   "description": "Datum waarop de aangifte is ingediend" },
        { "lang": "en-US", "label": "Filing date",       "description": "Date on which the tax return was filed" }
      ],
      "sd": "always"
    },
    {
      "path": ["verzamelinkomen"],
      "display": [
        { "lang": "nl-NL", "label": "Verzamelinkomen",   "description": "Verzamelinkomen in hele euro's" },
        { "lang": "en-US", "label": "Aggregated income", "description": "Aggregated income in whole euros" }
      ],
      "sd": "always",
      "svg_id": "verzamelinkomen"
    },
    {
      "path": ["inkomen_box1"],
      "display": [
        { "lang": "nl-NL", "label": "Inkomen box 1",     "description": "Belastbaar inkomen uit werk en woning" },
        { "lang": "en-US", "label": "Box 1 income",      "description": "Taxable income from work and home" }
      ],
      "sd": "always"
    },
    {
      "path": ["inkomen_box2"],
      "display": [
        { "lang": "nl-NL", "label": "Inkomen box 2",     "description": "Belastbaar inkomen uit aanmerkelijk belang" },
        { "lang": "en-US", "label": "Box 2 income",      "description": "Taxable income from substantial interest" }
      ],
      "sd": "always"
    },
    {
      "path": ["inkomen_box3"],
      "display": [
        { "lang": "nl-NL", "label": "Inkomen box 3",     "description": "Belastbaar inkomen uit sparen en beleggen" },
        { "lang": "en-US", "label": "Box 3 income",      "description": "Taxable income from savings and investments" }
      ],
      "sd": "always"
    },
    {
      "path": ["aangifte_status"],
      "display": [
        { "lang": "nl-NL", "label": "Status",            "description": "Status van de aangifte (bijv. Ingediend, Aangeslagen)" },
        { "lang": "en-US", "label": "Status",            "description": "Status of the tax return (e.g. Filed, Assessed)" }
      ],
      "sd": "always"
    },
    {
      "path": ["verklaring_tekst"],
      "display": [
        { "lang": "nl-NL", "label": "Verklaring",        "description": "Tekst van de inkomensverklaring" },
        { "lang": "en-US", "label": "Statement",         "description": "Text of the income statement" }
      ],
      "sd": "always"
    }
  ],
  "schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Inkomensverklaring VCT Schema",
    "description": "JSON schema voor nl.gbo.belastingdienst.inkomensverklaring",
    "type": "object",
    "properties": {
      "vct":                       { "type": "string" },
      "vct#integrity":             { "type": "string" },
      "iss":                       { "type": "string" },
      "nbf":                       { "type": "number" },
      "exp":                       { "type": "number" },
      "cnf":                       { "type": "object" },
      "status":                    { "type": "object" },
      "sub":                       { "type": "string" },
      "iat":                       { "type": "number" },
      "attestation_qualification": { "type": "string" },
      "belastingjaar":             { "type": "integer" },
      "indieningsdatum":           { "type": "string", "format": "date" },
      "verzamelinkomen":           { "type": "integer" },
      "inkomen_box1":              { "type": "integer" },
      "inkomen_box2":              { "type": "integer" },
      "inkomen_box3":              { "type": "integer" },
      "aangifte_status":           { "type": "string" },
      "verklaring_tekst":          { "type": "string" }
    },
    "required": ["vct", "iss", "attestation_qualification", "belastingjaar", "verzamelinkomen"]
  }
}
