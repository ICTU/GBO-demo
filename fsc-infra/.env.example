# Copy to .env for local overrides. `.env` is git-ignored.
#
# Compose picks .env up automatically when it lives next to the
# docker-compose.yml being invoked.

# Shared postgres password for all fsc-infra database users
# (three orgs × controller/manager/txlog + directory). Default is fine
# for a local demo (containers only talk to each other over the compose
# network). Replace in any real deployment.
FSC_POSTGRES_PASSWORD=postgres
